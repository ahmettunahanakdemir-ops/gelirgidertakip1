rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if owns(userId);

      match /transactions/{transactionId} {
        allow read, delete: if owns(userId);
        allow create, update: if owns(userId)
          && request.resource.data.id is string
          && request.resource.data.type in ["income", "expense", "transfer"]
          && request.resource.data.title is string
          && request.resource.data.amount is number
          && request.resource.data.category is string
          && request.resource.data.paymentMethod is string
          && request.resource.data.paymentAccountId is string
          && request.resource.data.transferAccountId is string
          && request.resource.data.transferFee is number
          && request.resource.data.date is string
          && request.resource.data.note is string
          && request.resource.data.transactionAt is string
          && request.resource.data.createdAt is string
          && (request.resource.data.updatedAt is string || request.resource.data.updatedAt is timestamp);
      }
    }
  }
}
